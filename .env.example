# Copy this to .env and adjust.

# Ollama OpenAI-compatible chat endpoint (default local install)
OLLAMA_BASE_URL=http://localhost:11434/v1

# Model tag as registered in Ollama  (run: `ollama list` to see installed models)
MODEL_NAME=qwen2.5:7b

# Embeddings run locally via sentence-transformers (no Ollama pull needed)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Ollama ignores the key, but the OpenAI client requires a non-empty string
OLLAMA_API_KEY=ollama
